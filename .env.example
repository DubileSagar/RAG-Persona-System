# Copy this to .env and fill in your values
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Path to the CSV file (relative to project root)
CSV_PATH=data/conversations.csv

# Similarity threshold for topic change detection (0.0 - 1.0)
# Lower = more sensitive to topic changes; tuned to 0.35 after testing
TOPIC_SIMILARITY_THRESHOLD=0.35

# Minimum messages between checkpoints to avoid over-segmentation
MIN_MSGS_BETWEEN_CHECKPOINTS=15

# FastAPI server settings
HOST=0.0.0.0
PORT=8000
